---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - Nick Frost" description="The page you're looking for doesn't exist.">
  <section class="min-h-screen flex items-center pt-14">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-6xl font-bold text-white tracking-tighter mb-4">404</p>
        <p class="text-lg text-zinc-400 mb-8">The page you're looking for doesn't exist.</p>
        <a href="/" class="btn-primary inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-white text-zinc-950 text-sm font-semibold hover:bg-zinc-200 transition-colors min-h-[44px]">
          Back to Home
        </a>
      </div>
    </div>
  </section>
</Layout>
