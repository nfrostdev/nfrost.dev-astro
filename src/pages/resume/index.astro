---
import ResumeLayout from '../../components/ResumeLayout.astro';
import { skills } from '../../lib/data';

const experience = [
  {
    company: 'Hippo Manager Software, Inc.',
    role: 'Engineering Manager',
    period: '2022 - 2025',
    bullets: [
      'Led engineering team; owned AWS, GitHub, and company-wide technical administration.',
      'Cut AWS costs by $6,000+/month through infrastructure refinements upon promotion.',
      'Migrated local development stack and eligible AWS infrastructure to Docker.',
      'Drove product direction, created Figma prototypes, and gathered feature feedback from veterinary clients.',
      'Maintained the platform through end of life after acquisition by Shepherd Veterinary Software.',
    ],
  },
  {
    company: 'Kalamazoo Valley Community College',
    role: 'Technical Lead',
    period: '2017 - 2022',
    bullets: [
      'Shipped 11+ web applications end-to-end: Vue.js front-ends, back-end APIs, data seeders, and CI/CD.',
      'Replaced legacy institutional systems, including an early-2000s department directory and several manual admin workflows.',
      'Solved multi-system authentication pass-through and cron-based data seeding from network-restricted Oracle sources.',
      'Ran requirement-gathering meetings across academic departments, HR, and faculty.',
    ],
  },
];

const projects = [
  {
    name: 'The L.I.V.E. Outreach',
    company: 'L.I.V.E. Outreach (nonprofit)',
    tech: 'Astro, TypeScript, Tailwind CSS, Keystatic, Cloudflare',
    description: 'Built and launched a full nonprofit website with an in-browser CMS, automated social share cards, structured data for search and AI discoverability, and a 100/100 accessibility score on every page.',
  },
  {
    name: 'Hippo Manager 2.0',
    company: 'Hippo Manager Software, Inc.',
    tech: 'Vue.js, Laravel, GraphQL, MySQL, Amazon Web Services (AWS), Docker, Tailwind CSS',
    description: 'Cloud-based practice management platform for veterinary clinics covering billing, scheduling, client management, reporting, and treatments.',
  },
];

const keywords = 'Engineering Manager, Technical Lead, Software Engineering, Team Leadership, Vue.js, Laravel, JavaScript, TypeScript, PHP, GraphQL, CSS, HTML, Astro, Hugo, Nuxt, Tailwind CSS, Amazon Web Services, AWS, Docker, MySQL, PostgreSQL, Firebase, Cloudflare, GitHub Actions, CI/CD, Figma, Git, Jira, Infrastructure Management, Agile, SaaS';
---

<ResumeLayout
  title="Resume - Nick Frost"
  description="Resume for Nick Frost, Engineering Manager based in Kalamazoo, MI."
  keywords={keywords}
  experience={experience}
  projects={projects}
  skills={skills}
/>
