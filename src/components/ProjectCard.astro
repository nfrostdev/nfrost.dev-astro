---
import { Image } from 'astro:assets';
import TechBadge from './TechBadge.astro';
import { hasIcon } from '../lib/techIcons';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  client?: string;
  description: string;
  tags: string[];
  image?: ImageMetadata;
  href?: string;
  repo?: string;
  isFirst?: boolean;
}

const { title, client, description, tags, image, href, repo, isFirst = false } = Astro.props;

const hrefLabel = href ? new URL(href).hostname.replace(/^www\./, '') : '';
---

<article class="group flex flex-col lg:flex-row items-start gap-8 py-12 first:pt-0 border-b border-zinc-800/50 last:border-b-0" data-animate>

  <!-- Image -->
  {image && (
    <div class="project-image w-full lg:w-3/5 rounded-lg shrink-0 border border-zinc-800 cursor-pointer md:cursor-zoom-in transition-transform duration-300 hover:scale-[1.02] overflow-hidden">
      <Image
        src={image}
        alt={`${title} screenshot`}
        class="lightbox-trigger w-full object-cover object-top rounded-lg shadow-lg"
        loading={isFirst ? 'eager' : 'lazy'}
        fetchpriority={isFirst ? 'high' : 'auto'}
        decoding="async"
        widths={[600, 900, 1200]}
        sizes="(max-width: 1024px) 100vw, 60vw"
      />
    </div>
  )}

  <!-- Text -->
  <div class={`flex flex-col gap-3 w-full ${image ? 'lg:w-2/5' : ''}`}>
    <div>
      <h3 class="font-bold text-lg text-white leading-snug tracking-tight">{title}</h3>
      {client && <p class="text-sm text-zinc-300 font-medium mt-0.5">{client}</p>}
      {(repo || href) && (
        <div class="flex items-center gap-2 mt-2">
          {repo && (
            <a href={repo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-11 h-11 rounded text-zinc-400 hover:text-zinc-200 transition-colors" aria-label={`Source code for ${title} (opens in new tab)`}>
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
            </a>
          )}
          {href && (
            <a href={href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 min-h-[44px] px-2 -mx-2 rounded text-sm text-zinc-400 hover:text-zinc-200 transition-colors">
              {hrefLabel}
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 3h6v6"/>
                <path d="M10 14 21 3"/>
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              </svg>
              <span class="sr-only">(opens in new tab)</span>
            </a>
          )}
        </div>
      )}
    </div>
    <p class="text-sm text-zinc-400 leading-relaxed">{description}</p>
    <div class="flex flex-wrap gap-x-2 gap-y-2.5" aria-label="Technologies used">
      {tags.filter(hasIcon).map(tag => (
        <TechBadge name={tag} />
      ))}
    </div>
  </div>

</article>
